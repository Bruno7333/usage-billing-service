# Copy to .env and fill in real values. Never commit .env.

# Postgres (matches docker-compose.yml)
DATABASE_URL="postgresql://postgres:password@localhost:5432/billing"

# Stripe (test mode) — dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_..."

# Price ID of the recurring $29/mo "Pro" product (Product catalog -> Pro -> Pricing)
STRIPE_PRO_PRICE_ID="price_..."

# Printed by `stripe listen --forward-to localhost:3000/webhooks/stripe`
STRIPE_WEBHOOK_SECRET="whsec_..."

# Optional, defaults to 3000
# PORT=3000
